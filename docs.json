{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "MemoryBase",
  "colors": {
    "primary": "#71717a",
    "light": "#ffffff",
    "dark": "#27272a"
  },
  "favicon": "/public/favicon.ico",
  "logo": {
    "light": "/public/icon-light.svg",
    "dark": "/public/icon-dark.svg"
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#ffffff",
      "dark": "#131419"
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Sign in",
      "href": "https://dashboard.memorybase.app/sign-in"
    }
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/6CnJ72D8Va"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Features",
            "pages": [
              "features/conversations",
              "features/projects",
              "features/context-packs"
            ]
          },
          {
            "group": "Claude Code & Codex",
            "pages": [
              "coding-tools/overview",
              "coding-tools/setup",
              "coding-tools/usage"
            ]
          },
          {
            "group": "AI Agents",
            "pages": [
              "ai-agents/overview",
              "ai-agents/setup",
              "ai-agents/workflows"
            ]
          }
        ]
      },
      {
        "tab": "MemoryBase CLI",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["cli/overview"]
          },
          {
            "group": "Commands",
            "pages": [
              "cli/search",
              "cli/projects",
              "cli/timeline",
              "cli/status",
              "cli/mcp"
            ]
          }
        ]
      },
      {
        "tab": "MemoryBase MCP",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["mcp/overview"]
          },
          {
            "group": "Tools",
            "pages": [
              "mcp/search-memory",
              "mcp/search-text",
              "mcp/memory-status",
              "mcp/list-projects",
              "mcp/get-project-context",
              "mcp/list-conversations",
              "mcp/get-conversation",
              "mcp/get-timeline",
              "mcp/get-timeline-for-date"
            ]
          }
        ]
      }
    ]
  }
}
